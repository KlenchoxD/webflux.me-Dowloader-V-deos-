    <!-- shadow under the play triangle -->
    <path
        android:pathData="M 47,49 L 61,55 L 47,61 Z"
        android:fillColor="#44000000" />
    <path
        android:pathData="M 46,48 L 60,54 L 46,60 Z"
        android:fillColor="#FFFFFF" />
