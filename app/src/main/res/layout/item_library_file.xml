<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@drawable/maybox_card_bg"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp">

    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/maybox_icon_badge_bg">

        <ImageView
            android:id="@+id/lib_item_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_movie"
            android:tint="#E60A15"
            android:contentDescription="@null"/>

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/lib_item_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#F1F5F9"
            android:maxLines="1"
            android:ellipsize="end"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/lib_item_ext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#E60A15"
                android:background="@drawable/maybox_icon_badge_bg"
                android:paddingHorizontal="4dp"
                android:paddingVertical="1dp"/>

            <TextView
                android:id="@+id/lib_item_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#94A3B8"
                android:layout_marginStart="6dp"/>

            <TextView
                android:id="@+id/lib_item_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#64748B"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

    </LinearLayout>

    <ImageView
        android:id="@+id/lib_item_delete"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_delete"
        android:tint="#64748B"
        android:padding="4dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@null"/>

</LinearLayout>
