<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Style.MayBox.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/lib_item_icon_container"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/colorIconBackground"
                app:cardElevation="0dp">
                <ImageView
                    android:id="@+id/lib_item_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_movie"
                    app:tint="@color/colorPrimary" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_toEndOf="@id/lib_item_icon_container"
                android:layout_toStartOf="@id/lib_item_delete"
                android:layout_centerVertical="true"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/lib_item_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Video Title Project.mp4"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorOnSurface"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/lib_item_ext"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MP4"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="1dp"
                        android:background="@drawable/maybox_chip_bg_small" />

                    <TextView
                        android:id="@+id/lib_item_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="14.2 MB"
                        android:textSize="12sp"
                        android:textColor="@color/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/lib_item_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="24 Oct 2023"
                        android:textSize="12sp"
                        android:textColor="@color/colorOnSurfaceVariant" />
                </LinearLayout>
            </LinearLayout>

            <ImageView
                android:id="@+id/lib_item_delete"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="4dp"
                android:src="@drawable/ic_delete"
                app:tint="@color/colorOnSurfaceVariant"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

        </RelativeLayout>

        <!-- Dynamic Progress Section (Visible only when downloading/paused) -->
        <LinearLayout
            android:id="@+id/lib_item_progress_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:visibility="gone">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/lib_item_status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Downloading..."
                    android:textSize="12sp"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/lib_item_progress_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="742 MB / 1.2 GB (62%)"
                    android:textSize="12sp"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:visibility="gone" />
            </RelativeLayout>

            <ProgressBar
                android:id="@+id/lib_item_progress_bar"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:progress="62"
                android:progressDrawable="@drawable/maybox_progress_drawable"
                android:visibility="gone" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/lib_item_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="14.2 MB/s"
                    android:textColor="@color/colorPrimary"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/lib_item_action_btn"
                    style="@style/Style.MayBox.Button.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_alignParentEnd="true"
                    android:text="PAUSE"
                    android:textSize="11sp"
                    app:icon="@drawable/ic_pause"
                    app:iconSize="14dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />
            </RelativeLayout>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
