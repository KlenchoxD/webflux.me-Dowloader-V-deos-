<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080808">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:gravity="center_vertical">

        <FrameLayout
            android:id="@+id/library_back_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/maybox_empty_state_bg">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_back"
                android:tint="#F1F5F9"
                android:contentDescription="@null"/>
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Downloads"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#F1F5F9"
            android:gravity="center"/>

        <View
            android:layout_width="40dp"
            android:layout_height="40dp"/>

    </LinearLayout>

    <!-- TAB BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/maybox_card_bg"
        android:paddingHorizontal="8dp">

        <TextView
            android:id="@+id/library_tab_history"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="History"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#E60A15"/>

        <TextView
            android:id="@+id/library_tab_active"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Active"
            android:textSize="13sp"
            android:textColor="#64748B"/>

        <TextView
            android:id="@+id/library_tab_scheduled"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Scheduled"
            android:textSize="13sp"
            android:textColor="#64748B"/>

    </LinearLayout>

    <!-- CONTENT AREA -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- FILE LIST -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/library_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false"
            android:visibility="gone"/>

        <!-- EMPTY STATE -->
        <LinearLayout
            android:id="@+id/library_empty_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_file_download"
                android:tint="#64748B"
                android:contentDescription="@null"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="No downloads yet"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#64748B"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Downloaded videos will appear here"
                android:textSize="12sp"
                android:textColor="#475569"
                android:gravity="center"/>

        </LinearLayout>

        <!-- PLACEHOLDER (Active/Scheduled) -->
        <LinearLayout
            android:id="@+id/library_placeholder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_hourglass_top"
                android:tint="#64748B"
                android:contentDescription="@null"/>

            <TextView
                android:id="@+id/library_placeholder_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="No active downloads"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#64748B"/>

        </LinearLayout>

    </FrameLayout>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="@drawable/maybox_nav_bg"
        android:paddingTop="1dp">

        <!-- HOME (inactive) -->
        <LinearLayout
            android:id="@+id/library_nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                android:tint="#64748B"
                android:contentDescription="@null"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Home"
                android:textSize="10sp"
                android:textColor="#64748B"/>

        </LinearLayout>

        <!-- LIBRARY (active) -->
        <LinearLayout
            android:id="@+id/library_nav_library"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_file_download"
                android:tint="#E60A15"
                android:contentDescription="@null"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Library"
                android:textSize="10sp"
                android:textColor="#E60A15"/>

        </LinearLayout>

        <!-- MORE (inactive) -->
        <LinearLayout
            android:id="@+id/library_nav_more"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                android:tint="#64748B"
                android:contentDescription="@null"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="More"
                android:textSize="10sp"
                android:textColor="#64748B"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
