<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/maybox_bottom_sheet_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="96dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Handle bar — sin margen extra arriba -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="2dp"
                android:background="#33FFFFFF"/>

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="Download as:"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#F1F5F9"/>

            <!-- Preview card -->
            <LinearLayout
                android:id="@+id/bs_preview_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="10dp"
                android:padding="12dp"
                android:background="@drawable/vdown_preview_card_bg">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/vdown_thumbnail_bg">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_play_arrow"
                        android:tint="#FFFFFF"/>

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/bs_title_preview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Video"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#F1F5F9"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/bs_url_preview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"
                        android:maxLines="1"
                        android:ellipsize="middle"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Music Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="10dp"
                android:paddingBottom="6dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_music_note"
                    android:tint="#E60A15"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Music"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#F1F5F9"/>

            </LinearLayout>

            <!-- M4A -->
            <LinearLayout
                android:id="@+id/bs_option_m4a"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="8dp"
                android:layout_marginVertical="2dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:background="@drawable/maybox_option_row_bg"
                android:foreground="?android:attr/selectableItemBackground">

                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/maybox_icon_badge_red">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_file_download"
                        android:tint="#E60A15"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fast (M4A)"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#F1F5F9"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.2 MB • Optimized for speed"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"/>
                </LinearLayout>

                <RadioButton
                    android:id="@+id/bs_radio_m4a"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:button="@drawable/maybox_radio_selector"
                    android:clickable="false"
                    android:focusable="false"/>

            </LinearLayout>

            <!-- MP3 -->
            <LinearLayout
                android:id="@+id/bs_option_mp3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="8dp"
                android:layout_marginVertical="2dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:background="@drawable/maybox_option_row_bg"
                android:foreground="?android:attr/selectableItemBackground">

                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/maybox_icon_badge_gray">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_music_note"
                        android:tint="#94A3B8"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MP3 Classic"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#F1F5F9"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12.8 MB • High Bitrate (320kbps)"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"/>
                </LinearLayout>

                <RadioButton
                    android:id="@+id/bs_radio_mp3"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:button="@drawable/maybox_radio_selector"
                    android:clickable="false"
                    android:focusable="false"/>

            </LinearLayout>

            <!-- Video Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="6dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_play_arrow"
                    android:tint="#E60A15"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Video"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#F1F5F9"/>

            </LinearLayout>

            <!-- 360p -->
            <LinearLayout
                android:id="@+id/bs_option_360p"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="8dp"
                android:layout_marginVertical="2dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:background="@drawable/maybox_option_row_bg"
                android:foreground="?android:attr/selectableItemBackground">

                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/maybox_icon_badge_subtle">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_file_download"
                        android:tint="#94A3B8"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fast (360p)"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#F1F5F9"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="24.5 MB • MP4"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"/>
                </LinearLayout>

                <RadioButton
                    android:id="@+id/bs_radio_360p"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:button="@drawable/maybox_radio_selector"
                    android:clickable="false"
                    android:focusable="false"/>

            </LinearLayout>

            <!-- 720p -->
            <LinearLayout
                android:id="@+id/bs_option_720p"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="8dp"
                android:layout_marginVertical="2dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:background="@drawable/maybox_option_row_bg"
                android:foreground="?android:attr/selectableItemBackground">

                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/maybox_icon_badge_subtle">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_play_arrow"
                        android:tint="#94A3B8"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="High Quality (720p)"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#F1F5F9"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="114.2 MB • HD Video"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"/>
                </LinearLayout>

                <RadioButton
                    android:id="@+id/bs_radio_720p"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:button="@drawable/maybox_radio_selector"
                    android:clickable="false"
                    android:focusable="false"
                    android:checked="true"/>

            </LinearLayout>

            <!-- More formats toggle -->
            <LinearLayout
                android:id="@+id/bs_more_formats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackgroundBorderless">

                <TextView
                    android:id="@+id/bs_more_formats_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="More formats"
                    android:textSize="13sp"
                    android:textColor="#94A3B8"/>

                <ImageView
                    android:id="@+id/bs_more_formats_arrow"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_arrow_forward"
                    android:rotation="90"
                    android:tint="#94A3B8"/>

            </LinearLayout>

            <!-- Contenedor expandible: 1080p + Best Quality — GONE por defecto -->
            <LinearLayout
                android:id="@+id/bs_extra_formats_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- 1080p -->
                <LinearLayout
                    android:id="@+id/bs_option_1080p"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginHorizontal="8dp"
                    android:layout_marginVertical="2dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp"
                    android:background="@drawable/maybox_option_row_bg"
                    android:foreground="?android:attr/selectableItemBackground">

                    <FrameLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/maybox_icon_badge_subtle">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_play_arrow"
                            android:tint="#94A3B8"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Full HD (1080p)"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#F1F5F9"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Best quality • MP4"
                            android:textSize="12sp"
                            android:textColor="#94A3B8"/>
                    </LinearLayout>

                    <RadioButton
                        android:id="@+id/bs_radio_1080p"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:button="@drawable/maybox_radio_selector"
                        android:clickable="false"
                        android:focusable="false"/>

                </LinearLayout>

                <!-- Best Quality -->
                <LinearLayout
                    android:id="@+id/bs_option_best_quality"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginHorizontal="8dp"
                    android:layout_marginVertical="2dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp"
                    android:background="@drawable/maybox_option_row_bg"
                    android:foreground="?android:attr/selectableItemBackground">

                    <FrameLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/maybox_icon_badge_red">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_star"
                            android:tint="#E60A15"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Best Quality"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#F1F5F9"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Max resolution • bestvideo+bestaudio"
                            android:textSize="12sp"
                            android:textColor="#94A3B8"/>
                    </LinearLayout>

                    <RadioButton
                        android:id="@+id/radio_best_quality"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:button="@drawable/maybox_radio_selector"
                        android:clickable="false"
                        android:focusable="false"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Footer fijo -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:layout_gravity="bottom">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/vdown_bottom_gradient_fade"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/bs_download_btn"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="18dp"
            android:text="DOWNLOAD NOW"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.05"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            app:backgroundTint="#E53935"
            app:cornerRadius="26dp"
            app:icon="@drawable/ic_file_download"
            app:iconTint="#FFFFFF"
            app:iconGravity="textStart"/>

    </FrameLayout>

</FrameLayout>