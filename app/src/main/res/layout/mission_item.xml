<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/maybox_card_bg"
    android:layout_marginHorizontal="0dp"
    android:layout_marginVertical="6dp">

    <!-- Progress background overlay (ProgressDrawable set here by MissionAdapter) -->
    <View
        android:id="@+id/item_bkg"
        android:layout_width="match_parent"
        android:layout_height="4dp"/>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- File type icon badge -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/maybox_icon_badge_bg">

            <ImageView
                android:id="@+id/item_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:tint="#E60A15"
                android:contentDescription="@null"/>

        </FrameLayout>

        <!-- Middle: name, size, date -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginHorizontal="10dp">

            <org.schabi.newpipe.views.NewPipeTextView
                android:id="@+id/item_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F1F5F9"
                android:textSize="14sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="filename.mp4"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <org.schabi.newpipe.views.NewPipeTextView
                    android:id="@+id/item_size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:text="0 MB"/>

                <org.schabi.newpipe.views.NewPipeTextView
                    android:id="@+id/item_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:text=""/>

            </LinearLayout>

            <!-- Status / speed text -->
            <org.schabi.newpipe.views.NewPipeTextView
                android:id="@+id/item_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#E60A15"
                android:textSize="11sp"
                android:textStyle="bold"
                android:text="0%"/>

        </LinearLayout>

        <!-- More / options button -->
        <ImageView
            android:id="@+id/item_more"
            style="?attr/buttonBarButtonStyle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:scaleType="center"
            android:src="@drawable/ic_more_vert"
            android:tint="#64748B"
            android:contentDescription="@null"/>

    </LinearLayout>

</LinearLayout>
