<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/home_header"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/colorPrimary"
                app:cardElevation="0dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="M"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="MayBox"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#2A2A2A"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#26E53935"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_account_circle_white_24dp"
                android:padding="6dp"
                android:scaleType="centerCrop"
                app:tint="@color/colorOnSurfaceVariant" />
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/home_header"
        app:layout_constraintBottom_toTopOf="@id/vdown_bottom_nav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- CARD "Ready to download?" -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Style.MayBox.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ready to download?"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Paste any video link below to begin"
                        android:textSize="14sp"
                        android:textColor="#888888"
                        android:layout_marginTop="4dp" />

                    <!-- Campo URL -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/maybox_input_bg_v2"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_share"
                            app:tint="#555555" />

                        <EditText
                            android:id="@+id/vdown_url_input"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="8dp"
                            android:background="@android:color/transparent"
                            android:hint="https://..."
                            android:textColorHint="#888888"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:singleLine="true"
                            android:inputType="textUri"
                            android:imeOptions="actionDone" />

                        <Button
                            android:id="@+id/vdown_paste_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="PASTE"
                            android:textColor="@color/colorPrimary"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:stateListAnimator="@null"
                            android:paddingHorizontal="8dp"
                            style="?android:attr/borderlessButtonStyle"
                            android:minWidth="0dp"
                            android:minHeight="0dp" />
                    </LinearLayout>

                    <!-- Botón Descargar -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/vdown_download_btn"
                        style="@style/Style.MayBox.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:text="Download Video"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:icon="@drawable/ic_file_download"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECCIÓN "SUPPORTED PLATFORMS" -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="16dp"
                        android:background="@color/colorPrimary"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        style="@style/Style.MayBox.SectionLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SUPPORTED PLATFORMS" />
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:paddingHorizontal="16dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- YouTube -->
                        <LinearLayout
                            android:id="@+id/vdown_chip_youtube"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/maybox_chip_bg_small"
                            android:backgroundTint="#1A1A1A"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="10dp"
                            android:layout_marginEnd="8dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_play_arrow"
                                app:tint="#FF0000" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="YouTube"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <!-- Instagram -->
                        <LinearLayout
                            android:id="@+id/vdown_chip_instagram"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/maybox_chip_bg_small"
                            android:backgroundTint="#1A1A1A"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="10dp"
                            android:layout_marginEnd="8dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_camera_white_24dp"
                                app:tint="#E1306C" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="Instagram"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <!-- TikTok -->
                        <LinearLayout
                            android:id="@+id/vdown_chip_tiktok"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/maybox_chip_bg_small"
                            android:backgroundTint="#1A1A1A"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="10dp"
                            android:layout_marginEnd="8dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_music_note"
                                app:tint="#69C9D0" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="TikTok"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <!-- Twitter/X -->
                        <LinearLayout
                            android:id="@+id/vdown_chip_twitter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/maybox_chip_bg_small"
                            android:backgroundTint="#1A1A1A"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="10dp"
                            android:layout_marginEnd="8dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_public"
                                app:tint="#FFFFFF" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="Twitter"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <!-- Facebook -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/maybox_chip_bg_small"
                            android:backgroundTint="#1A1A1A"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="10dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_public"
                                app:tint="#1877F2" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="Facebook"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp" />
                        </LinearLayout>

                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- SECCIÓN "RECENT DOWNLOADS" -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:paddingHorizontal="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_alignParentStart="true">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="16dp"
                            android:background="@color/colorPrimary"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            style="@style/Style.MayBox.SectionLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RECENT DOWNLOADS" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="See all ›"
                        android:textSize="13sp"
                        android:textColor="@color/colorPrimary"
                        android:textStyle="bold"
                        android:background="?android:attr/selectableItemBackground"
                        android:padding="4dp" />
                </RelativeLayout>

                <!-- Status de historial vacío y la lista en sí -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">

                    <LinearLayout
                        android:id="@+id/vdown_recent_empty"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_history"
                            app:tint="#333333" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Your download history will appear here"
                            android:textSize="14sp"
                            android:textColor="#666666" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/vdown_recent_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM NAVIGATION BAR -->
    <LinearLayout
        android:id="@+id/vdown_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:background="#111111"
        android:elevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/vdown_nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                app:tint="@color/colorPrimary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Home"
                android:textSize="11sp"
                android:textColor="@color/colorPrimary"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/vdown_nav_library"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_folder_white_24dp"
                app:tint="#555555" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Library"
                android:textSize="11sp"
                android:textColor="#555555" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/vdown_nav_more"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_more_horiz"
                app:tint="#555555" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="More"
                android:textSize="11sp"
                android:textColor="#555555" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
