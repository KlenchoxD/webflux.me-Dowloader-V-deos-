<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080808">

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- [1] HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="24dp"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_logo_red">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_play_arrow"
                        android:tint="#FFFFFF"
                        android:contentDescription="@null"/>
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="MayBox"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#E60A15"/>

                <ImageView
                    android:id="@+id/vdown_profile_icon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_account_circle_white_24dp"
                    android:tint="#E60A15"
                    android:contentDescription="@null"/>

            </LinearLayout>

            <!-- [2] MAIN CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/maybox_card_bg"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ready to download?"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#F1F5F9"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Paste any video link below to begin"
                    android:textSize="14sp"
                    android:textColor="#94A3B8"/>

                <!-- Input row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/maybox_input_bg"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="12dp"
                        android:src="@drawable/ic_share"
                        android:tint="#64748B"
                        android:contentDescription="@null"/>

                    <EditText
                        android:id="@+id/vdown_url_input"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:hint="Paste video URL"
                        android:textColorHint="#64748B"
                        android:textColor="#F1F5F9"
                        android:textSize="14sp"
                        android:background="@null"
                        android:singleLine="true"
                        android:inputType="textUri"
                        android:imeOptions="actionGo"/>

                    <Button
                        android:id="@+id/vdown_paste_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:text="PASTE"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#E60A15"
                        android:background="@drawable/maybox_paste_btn_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp"
                        android:elevation="0dp"
                        android:stateListAnimator="@null"/>

                </LinearLayout>

            </LinearLayout>

            <!-- [3] DOWNLOAD BUTTON -->
            <Button
                android:id="@+id/vdown_download_btn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:text="Download Video"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/maybox_download_btn_bg"
                android:drawableStart="@drawable/ic_file_download"
                android:drawablePadding="8dp"
                android:elevation="0dp"
                android:stateListAnimator="@null"/>

            <!-- [4] SUPPORTED PLATFORMS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SUPPORTED PLATFORMS"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#64748B"
                    android:letterSpacing="0.15"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- YouTube chip -->
                        <LinearLayout
                            android:id="@+id/vdown_chip_youtube"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/maybox_chip_bg"
                            android:paddingHorizontal="14dp"
                            android:layout_marginEnd="8dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_play_arrow"
                                android:tint="#FF0000"
                                android:contentDescription="@null"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="YouTube"
                                android:textSize="12sp"
                                android:textColor="#F1F5F9"/>

                        </LinearLayout>

                        <!-- Instagram chip -->
                        <LinearLayout
                            android:id="@+id/vdown_chip_instagram"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/maybox_chip_bg"
                            android:paddingHorizontal="14dp"
                            android:layout_marginEnd="8dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_camera_white_24dp"
                                android:tint="#E1306C"
                                android:contentDescription="@null"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="Instagram"
                                android:textSize="12sp"
                                android:textColor="#F1F5F9"/>

                        </LinearLayout>

                        <!-- TikTok chip -->
                        <LinearLayout
                            android:id="@+id/vdown_chip_tiktok"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/maybox_chip_bg"
                            android:paddingHorizontal="14dp"
                            android:layout_marginEnd="8dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_music_note"
                                android:tint="#69C9D0"
                                android:contentDescription="@null"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="TikTok"
                                android:textSize="12sp"
                                android:textColor="#F1F5F9"/>

                        </LinearLayout>

                        <!-- Twitter chip -->
                        <LinearLayout
                            android:id="@+id/vdown_chip_twitter"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/maybox_chip_bg"
                            android:paddingHorizontal="14dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_public"
                                android:tint="#1DA1F2"
                                android:contentDescription="@null"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="Twitter"
                                android:textSize="12sp"
                                android:textColor="#F1F5F9"/>

                        </LinearLayout>

                    </LinearLayout>
                </HorizontalScrollView>

            </LinearLayout>

            <!-- [5] RECENT DOWNLOADS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp">

                <!-- Section header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Recent Downloads"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#94A3B8"/>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_drop_down"
                        android:tint="#64748B"
                        android:contentDescription="@null"/>

                </LinearLayout>

                <!-- Empty state card -->
                <LinearLayout
                    android:id="@+id/vdown_recent_empty"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/maybox_empty_state_bg"
                    android:visibility="visible">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_history"
                        android:tint="#64748B"
                        android:contentDescription="@null"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="No recent downloads yet"
                        android:textSize="12sp"
                        android:textColor="#64748B"/>

                </LinearLayout>

                <!-- Recent items list (shown when files exist) -->
                <LinearLayout
                    android:id="@+id/vdown_recent_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- [6] BOTTOM NAV -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="@drawable/maybox_nav_bg"
        android:paddingTop="1dp">

        <!-- HOME (active) -->
        <LinearLayout
            android:id="@+id/vdown_nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                android:tint="#E60A15"
                android:contentDescription="@null"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Home"
                android:textSize="10sp"
                android:textColor="#E60A15"/>

        </LinearLayout>

        <!-- LIBRARY (inactive) -->
        <LinearLayout
            android:id="@+id/vdown_nav_library"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_file_download"
                android:tint="#64748B"
                android:contentDescription="@null"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Library"
                android:textSize="10sp"
                android:textColor="#64748B"/>

        </LinearLayout>

        <!-- MORE (inactive) -->
        <LinearLayout
            android:id="@+id/vdown_nav_more"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                android:tint="#64748B"
                android:contentDescription="@null"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="More"
                android:textSize="10sp"
                android:textColor="#64748B"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
